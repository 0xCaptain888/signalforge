# ══════════════════════════════════════════════
# SignalForge v2.1 — .env template
# Copy to .env and fill in real values.
# .env is gitignored — NEVER commit it.
# ══════════════════════════════════════════════

# ── CMC API ────────────────────────────────────
CMC_API_KEY=your_cmc_api_key_uuid_format
CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp
CMC_X402_BASE_URL=https://mcp.coinmarketcap.com/x402

# ── Base wallet (x402 payments) ────────────────
X402_PRIVATE_KEY=0x_your_base_wallet_private_key_64_hex
X402_PAYEE_ADDRESS=0x_your_wallet_address
X402_NETWORK=base
X402_PRICE_USDC=0.50
X402_DEMO_MODE=true

# ── BSC Testnet (BNB AI Agent SDK) ─────────────
WALLET_PASSWORD=strong_password_min_16_chars_remember_it
PRIVATE_KEY=0x_same_or_other_private_key_deletable_after_first_run
CLIENT_PRIVATE_KEY=
NETWORK=bsc-testnet
SERVICE_PRICE=10000000000000000000

# ── Pinata IPFS ────────────────────────────────
STORAGE_PROVIDER=ipfs
STORAGE_API_KEY=eyJ_your_full_pinata_jwt

# ── Skill service ──────────────────────────────
SKILL_HOST=0.0.0.0
SKILL_PORT=8000
SKILL_PUBLIC_URL=http://localhost:8000
APEX_PORT=8001
APEX_PUBLIC_URL=http://localhost:8001
VITE_SERVICE_URL=

# ── LLM (v1, kept) ─────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_key

# ── Trust Wallet Agent Kit (optional) ──────────
# TWAK_API_KEY=
# TWAK_ENDPOINT=
